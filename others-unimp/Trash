/* =========================================================
   FLOATING IMAGE SYSTEM
========================================================= */

.about-float {
  margin-bottom: 16px;
}

.about-float-right {
  float: right;
  margin-left: 16px;
  margin-top: 8px;
}

.about-float-left {
  float: left;
  margin-right: 16px;
  margin-top: 6px;
}

.about-float img {
  display: block;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.10);
  box-shadow:
    0 20px 40px rgba(0, 0, 0, 0.28),
    0 0 28px rgba(184, 136, 56, 0.10);
  background: rgba(255,255,255,0.03);
}

/* single / standard figure */
.about-mini-figure {
  margin: 0;
}

.about-mini-figure img {
  object-fit: cover;
  object-position: center top;
  border-radius: 24px;
}

.about-mini-figure figcaption {
  margin-top: 10px;
  font-size: 0.86rem;
  line-height: 1.6;
  color: var(--text-muted);
  text-align: center;
}

/* optional shorter portrait */
.about-short-portrait img {
  object-fit: cover;
  object-position: center 12%;
}

/* =========================================================
   TWO PHOTO STACK
========================================================= */

.about-photo-stack {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.about-photo-stack .about-mini-figure img {
  width: 100%;
}

.about-photo-stack .about-mini-figure figcaption {
  text-align: center;
}

/* =========================================================
   THREE PHOTO COLLAGE
========================================================= */

.about-photo-collage {
  width: min(340px, 36%);
  display: grid;
  grid-template-columns: 1.08fr 0.92fr;
  gap: 12px;
  margin-bottom: 18px;
}

.about-photo-collage.about-float-right {
  float: right;
  margin-left: 18px;
  margin-top: 8px;
}

.about-photo-collage.about-float-left {
  float: left;
  margin-right: 18px;
  margin-top: 8px;
}

.about-collage-main,
.about-collage-small {
  margin: 0;
}

.about-collage-main {
  grid-row: span 2;
}

.about-collage-main img {
  width: 100%;
  height: 100%;
  min-height: 320px;
  object-fit: cover;
  object-position: center;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.10);
  box-shadow:
    0 20px 40px rgba(0, 0, 0, 0.28),
    0 0 28px rgba(184, 136, 56, 0.10);
  background: rgba(255,255,255,0.03);
}

.about-collage-small img {
  width: 100%;
  height: 154px;
  object-fit: cover;
  object-position: center;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.10);
  box-shadow:
    0 14px 28px rgba(0, 0, 0, 0.22),
    0 0 18px rgba(184, 136, 56, 0.08);
  background: rgba(255,255,255,0.03);
}

.about-photo-note {
  grid-column: 1 / -1;
  margin-top: 2px;
  font-size: 0.84rem;
  line-height: 1.55;
  color: var(--text-muted);
  text-align: center;
}

/* recommendations section */

.about-recommendations-section {
  padding: 34px 0 60px;
}

.about-recommendations-panel {
  border-radius: 30px;
  padding: 40px 36px;
  text-align: center;

  background: linear-gradient(
    135deg,
    rgba(15, 33, 52, 0.84),
    rgba(10, 26, 43, 0.92),
    rgba(18, 38, 58, 0.84)
  );

  border: 1px solid rgba(255,255,255,0.06);
  box-shadow: var(--shadow-soft);
  position: relative;
  overflow: hidden;
}

.about-recommendations-panel::before {
  content: "";
  position: absolute;
  inset: 0;

  background:
    radial-gradient(circle at 22% 28%, rgba(184,136,56,0.10), transparent 20%),
    radial-gradient(circle at 78% 72%, rgba(64,100,140,0.12), transparent 24%);

  pointer-events: none;
}

.about-recommendations-panel > * {
  position: relative;
  z-index: 1;
}

.about-recommendations-panel h2 {
  font-size: clamp(2.2rem, 4vw, 3rem);
  margin-bottom: 18px;
  letter-spacing: -0.04em;
}

.about-recommendations-text {
  color: var(--text-soft);
  font-size: 1.05rem;
  line-height: 1.9;
  max-width: 720px;
  margin: 0 auto 18px;
}

/* =========================================================
   END PANEL
========================================================= */

.about-end-section {
  padding: 22px 0 46px;
}

.about-end-panel {
  border-radius: 30px;
  padding: 40px 34px;
  text-align: center;
  background: linear-gradient(
    135deg,
    rgba(17, 34, 53, 0.86),
    rgba(10, 25, 40, 0.95),
    rgba(21, 41, 62, 0.82)
  );
  border: 1px solid rgba(255,255,255,0.07);
  box-shadow: var(--shadow-soft);
}

.about-end-line {
  font-size: 1.18rem;
  line-height: 1.9;
  color: var(--text-main);
  max-width: 860px;
  margin: 0 auto 10px;
}

.about-end-line.soft {
  color: var(--accent-gold-light);
  margin-bottom: 0;
}

/* =========================================================
   RESPONSIVE
========================================================= */

@media (max-width: 980px) {
  .about-float,
  .about-float-left,
  .about-float-right,
  .about-photo-collage,
  .about-photo-collage.about-float-left,
  .about-photo-collage.about-float-right {
    float: none;
    width: 100%;
    max-width: 100%;
    margin: 0 0 20px 0;
  }

  .about-photo-collage {
    grid-template-columns: 1fr 1fr;
  }

  .about-collage-main {
    grid-column: 1 / -1;
    grid-row: auto;
  }

  .about-collage-main img {
    min-height: 260px;
  }

  .about-collage-small img {
    height: 180px;
  }

  .about-prose {
    padding: 30px 24px 26px;
  }

  .about-prose p {
    font-size: 0.98rem;
    line-height: 1.85;
  }

  .about-end-panel {
    padding: 32px 22px;
  }

  .about-end-line {
    font-size: 1.05rem;
  }
}

@media (max-width: 760px) {
  .about-hero-section {
    padding: 50px 0 18px;
  }

  .about-hero-wrap h1 {
    font-size: 2.8rem;
  }

  .about-hero-wrap h2 {
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .about-hero-text {
    font-size: 0.97rem;
    line-height: 1.85;
  }

  .about-prose h2 {
    font-size: 2.15rem;
  }

  .about-photo-collage {
    grid-template-columns: 1fr;
  }

  .about-collage-main img,
  .about-collage-small img,
  .about-short-portrait img {
    height: auto;
    min-height: unset;
    max-height: none;
  }
}